---
import Layout from '../layouts/Layout.astro';
import Whirlpool from '../components/preact/Whirlpool.jsx';
---

<Layout title="Whirlpool">
	<main class="container mx-auto p-4">
		<h1 class="text-4xl font-bold text-center mb-8">Whirlpool</h1>
		
		<div class="flex justify-center mb-8">
			<Whirlpool client:load />
		</div>

		<div class="max-w-2xl mx-auto">
			<h2 class="text-2xl font-semibold mb-4">How it Works</h2>
			<p class="mb-4">
				This simulation creates a mesmerizing whirlpool effect. Here's how it works:
			</p>
			<ul class="list-disc list-inside mb-4 space-y-2">
				<li>The simulation uses a grid of particles.</li>
				<li>Each particle is influenced by a central point, creating a swirling motion.</li>
				<li>The particles are colored based on their velocity, creating the visual effect of a whirlpool.</li>
			</ul>
		</div>
	</main>
</Layout>
