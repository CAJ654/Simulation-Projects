---
import Layout from '../layouts/Layout.astro';
import CityGeneration from '../components/react/CityGeneration.tsx';
---

<Layout title="City Generation">
	<main class="container mx-auto p-4">
		<h1 class="text-4xl font-bold text-center mb-8">City Generation</h1>
		
		<div class="flex justify-center mb-8">
			<CityGeneration client:load />
		</div>

		<div class="max-w-2xl mx-auto">
			<h2 class="text-2xl font-semibold mb-4">How it Works</h2>
			<p class="mb-4">
				This simulation procedurally generates a city layout. Here's how it works:
			</p>
			<ul class="list-disc list-inside mb-4 space-y-2">
				<li>The simulation starts with a grid of empty cells.</li>
				<li>A road is randomly placed on the grid.</li>
				<li>Buildings are then placed adjacent to the roads.</li>
				<li>The process repeats, with new roads branching off from existing ones, creating a city-like structure.</li>
			</ul>
		</div>
	</main>
</Layout>
