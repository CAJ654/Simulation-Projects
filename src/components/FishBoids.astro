<!-- The canvas element where the boid simulation will be rendered. -->
<canvas id="boids-canvas"></canvas>

<!-- Control Panel for adjusting simulation parameters -->
<div class="panel right-panel" id="control-panel">
    <h3>Controls</h3>
    <!-- Slider to control the number of boid flocks -->
    <label for="flock-slider">Number of Flocks: <span id="flock-count">1</span></label>
    <input type="range" id="flock-slider" min="1" max="10" value="1" style="width: 100%;">
    <!-- Slider to control the speed of the boids -->
    <label for="speed-slider">Speed: <span id="speed-value">4</span></label>
    <input type="range" id="speed-slider" min="1" max="10" value="4" step="0.1" style="width: 100%;">
    <!-- Container for sliders that control the size of stationary shapes -->
    <div id="stationary-shape-sliders-container"></div>
</div>

<!-- Shapes Panel for adding new shapes to the simulation -->
<div class="panel right-panel" id="shapes-panel" style="margin-top: 250px;">
    <h3>Shapes</h3>
    <!-- Draggable fish shape -->
    <div class="shape" draggable="true" data-shape="fish">🐟</div>
    <!-- Draggable triangle shape -->
    <div class="shape" draggable="true" data-shape="triangle">▲</div>
    <!-- Draggable square shape -->
    <div class="shape" draggable="true" data-shape="square">■</div>
</div>

<!-- Toggle Buttons to show/hide the panels -->
<div class="toggle-button" id="control-toggle-button">&gt;</div>
<div class="toggle-button" id="shapes-toggle-button">&gt;</div>

<!-- The main script for the boid simulation. Astro will handle bundling this script and its dependencies. -->
<script src="../scripts/fish-boids.js"></script>

<style>
    /* Style for the main canvas */
    canvas { 
        position: fixed;
        top: 0;
        left: 0;
        display: block; 
        background-color: #000;
    }

    /* Generic Panel Styles for control and shape panels */
    .panel {
        position: fixed;
        top: 0;
        width: 250px;
        background-color: rgba(0,0,0,0.7);
        padding: 20px;
        max-height: 100vh;
        overflow-y: auto;
        z-index: 10;
        transition: transform 0.3s ease;
        border: 1px solid #333;
    }
    .panel h3 { margin-top: 0; }
    .panel label { display: block; margin-bottom: 10px; }

    /* Styles for panels positioned on the right side of the screen */
    .right-panel {
        right: 0;
        transform: translateX(0);
    }
    /* Style for hidden right panels, moving them off-screen */
    .right-panel.hidden {
        transform: translateX(100%);
    }
    
    /* Generic style for toggle buttons that show/hide panels */
    .toggle-button {
        position: fixed;
        top: 20px;
        width: 30px;
        height: 30px;
        background-color: rgba(0,0,0,0.8);
        border: 1px solid #333;
        cursor: pointer;
        color: white;
        font-size: 20px;
        line-height: 30px;
        text-align: center;
        z-index: 20; /* Ensure buttons are above panels */
    }

    /* Positioning for the control panel's toggle button */
    #control-toggle-button {
        right: 290px; /* Positioned to the left of the panel */
        transition: right 0.3s ease;
    }
    /* Repositions the toggle button when the control panel is hidden */
    #control-panel.hidden ~ #control-toggle-button {
         right: 0px;
    }

    /* Positioning for the shapes panel's toggle button */
    #shapes-toggle-button {
        right: 290px; /* Positioned to the left of the panel */
        margin-top: 250px;
        transition: right 0.3s ease;
    }
   /* Repositions the toggle button when the shapes panel is hidden */
   #shapes-panel.hidden ~ #shapes-toggle-button {
        right: 0px;
   }

    /* Style for the draggable shape elements */
    .shape {
        font-size: 30px;
        cursor: grab;
        margin: 10px;
        display: inline-block;
    }
</style>